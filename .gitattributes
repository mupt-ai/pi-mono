# Default to LF for text files across the repo
* text=auto eol=lf

# Windows scripts should keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Shell scripts should keep LF
*.sh text eol=lf

# Always resolve package-lock.json to our version on merge, then regenerate.
# Requires `git config merge.ours.driver true` once per clone.
package-lock.json merge=ours

# Common binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.woff binary
*.woff2 binary
